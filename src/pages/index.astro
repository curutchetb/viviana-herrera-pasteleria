---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import GalleryMasonry from '../components/GalleryMasonry.astro';
import OrderConfigurator from '../components/OrderConfigurator.astro';
import FAQs from '../components/FAQs.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <main>
    <Hero />
    <OrderConfigurator />
    <GalleryMasonry />
    <About />
    <FAQs />
  </main>
  <Footer />

  <!-- MOBILE TAB BAR — solo visible en ≤768px -->
  <nav class="tab-bar" aria-label="Menú principal">
    <a href="#galeria" class="tab-item" aria-label="Ver galería">
      <span class="tab-icon">📸</span>
      <span class="tab-label">Galería</span>
    </a>
    <a href="#nosotros" class="tab-item" aria-label="Sobre mí">
      <span class="tab-icon">👩‍🍳</span>
      <span class="tab-label">Sobre mí</span>
    </a>
    <a href="#faqs" class="tab-item" aria-label="Preguntas frecuentes">
      <span class="tab-icon">❓</span>
      <span class="tab-label">Preguntas</span>
    </a>
    <a
      href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Quisiera%20consultar%20sobre%20un%20pedido"
      target="_blank"
      rel="noopener noreferrer"
      class="tab-item tab-item--wa"
      aria-label="Escribir por WhatsApp"
    >
      <span class="tab-icon">💬</span>
      <span class="tab-label">WhatsApp</span>
    </a>
  </nav>
</Layout>

<style>
  main {
    overflow: hidden;
    /* Espacio para el tab bar en mobile */
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    main {
      padding-bottom: 76px; /* altura del tab bar */
    }
  }

  /* ═══════════════════════════════════════════════
     TAB BAR — Solo mobile ≤768px
     
     Diseño pensado para personas mayores:
     - Siempre visible, sin interacción previa
     - Ícono grande + texto debajo = claro y legible
     - 3 ítems máximo (regla del pulgar)
     - "Pedir torta" destacado en rosa: es la acción principal
     - "WhatsApp" en verde: reconocible universalmente
     - Área táctil mínima: 64px de alto
  ═══════════════════════════════════════════════ */
  .tab-bar {
    display: none; /* oculto en desktop */
  }

  @media (max-width: 768px) {
    .tab-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 150;
      background: rgba(253, 251, 247, 0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 1px solid rgba(212, 165, 165, 0.2);
      box-shadow: 0 -4px 24px rgba(51, 33, 28, 0.08);
      padding-bottom: env(safe-area-inset-bottom, 0px);
      height: calc(64px + env(safe-area-inset-bottom, 0px));
      align-items: stretch;
    }

    .tab-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
      text-decoration: none;
      color: #9a8070;
      padding: 0.5rem 0.25rem;
      transition: background 0.15s ease, color 0.15s ease;
      border-radius: 0;
      position: relative;
      min-height: 64px;
      /* Área táctil generosa */
      -webkit-tap-highlight-color: rgba(212,165,165,0.2);
    }

    .tab-item:active {
      background: rgba(212, 165, 165, 0.12);
    }

    /* Pedir torta — destacado con pill rosada */
    .tab-item--primary {
      color: #B8857E;
    }

    .tab-item--primary .tab-icon {
      background: linear-gradient(135deg, #D4A5A5, #B8857E);
      border-radius: 14px;
      width: 44px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      box-shadow: 0 2px 8px rgba(184,133,126,0.35);
    }

    .tab-item--primary .tab-label {
      color: #B8857E;
      font-weight: 700;
    }

    /* WhatsApp — verde reconocible */
    .tab-item--wa {
      color: #25D366;
    }

    .tab-item--wa .tab-icon {
      background: #25D366;
      border-radius: 14px;
      width: 44px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      box-shadow: 0 2px 8px rgba(37,211,102,0.35);
    }

    .tab-item--wa .tab-label {
      color: #1aa050;
      font-weight: 700;
    }

    /* Ícono neutro (fotos) */
    .tab-item:not(.tab-item--primary):not(.tab-item--wa) .tab-icon {
      font-size: 1.3rem;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .tab-icon {
      font-size: 1.3rem;
      line-height: 1;
      transition: transform 0.15s ease;
    }

    .tab-item:active .tab-icon {
      transform: scale(0.9);
    }

    .tab-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-align: center;
      line-height: 1;
    }

    /* Separadores verticales sutiles entre ítems */
    .tab-item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 20%;
      height: 60%;
      width: 1px;
      background: rgba(212,165,165,0.2);
    }
  }
</style>
