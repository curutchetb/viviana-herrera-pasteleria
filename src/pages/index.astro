---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import OrderConfigurator from '../components/OrderConfigurator.astro';
import GalleryMasonry from '../components/GalleryMasonry.astro';
import About from '../components/About.astro';
import FAQs from '../components/FAQs.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <main>
    <Hero />
    <HowItWorks />
    <OrderConfigurator />
    <GalleryMasonry />
    <About />
    <FAQs />
  </main>
  <Footer />

  <!-- Botón volver arriba — aparece al scrollear -->
  <a href="#inicio" class="back-to-top" id="back-to-top" aria-label="Volver al inicio">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 19V5M5 12l7-7 7 7"/>
    </svg>
    <span>Inicio</span>
  </a>

  <!-- MOBILE TAB BAR — solo visible en ≤768px -->
  <nav class="tab-bar" aria-label="Menú principal">
    <a href="#galeria" class="tab-item" aria-label="Ver galería">
      <span class="tab-icon">📸</span>
      <span class="tab-label">Galería</span>
    </a>
    <a href="#nosotros" class="tab-item" aria-label="Sobre mí">
      <span class="tab-icon">👩‍🍳</span>
      <span class="tab-label">Sobre mí</span>
    </a>
    <a href="#faqs" class="tab-item" aria-label="Preguntas frecuentes">
      <span class="tab-icon">❓</span>
      <span class="tab-label">Preguntas</span>
    </a>
    <a
      href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Quisiera%20consultar%20sobre%20un%20pedido"
      target="_blank"
      rel="noopener noreferrer"
      class="tab-item tab-item--wa"
      aria-label="Escribir por WhatsApp"
    >
      <span class="tab-icon">💬</span>
      <span class="tab-label">WhatsApp</span>
    </a>
  </nav>
</Layout>

<script>
  // Botón volver arriba: aparece después de scrollear 400px
  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 400);
  });
</script>

<style>
  main {
    overflow: hidden;
  }

  @media (max-width: 768px) {
    main { padding-bottom: 76px; }
  }

  /* ═══════════════════════════════════════
     BOTÓN VOLVER ARRIBA
     Aparece en desktop Y mobile después de
     scrollear 400px. En mobile se ubica
     encima del tab bar.
  ═══════════════════════════════════════ */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 1.5rem;
    z-index: 140;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    background: white;
    color: var(--rosa-oscuro);
    padding: 0.65rem 0.85rem;
    border-radius: 14px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(51,33,28,0.12);
    border: 1.5px solid rgba(212,165,165,0.3);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    /* Oculto por defecto */
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease, box-shadow 0.2s ease;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background: var(--rosa-claro);
    box-shadow: 0 6px 24px rgba(184,133,126,0.25);
    transform: translateY(-2px);
  }

  /* En mobile: posicionado encima del tab bar */
  @media (max-width: 768px) {
    .back-to-top {
      bottom: calc(76px + 0.75rem);
      right: 1rem;
      padding: 0.6rem 0.75rem;
    }
  }

  /* ═══════════════════════════════════════
     TAB BAR
  ═══════════════════════════════════════ */
  .tab-bar {
    display: none;
  }

  @media (max-width: 768px) {
    .tab-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 150;
      background: rgba(253,251,247,0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 1px solid rgba(212,165,165,0.2);
      box-shadow: 0 -4px 24px rgba(51,33,28,0.08);
      padding-bottom: env(safe-area-inset-bottom, 0px);
      height: calc(64px + env(safe-area-inset-bottom, 0px));
      align-items: stretch;
    }

    .tab-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
      text-decoration: none;
      color: #9a8070;
      padding: 0.5rem 0.25rem;
      transition: background 0.15s ease, color 0.15s ease;
      position: relative;
      min-height: 64px;
      -webkit-tap-highlight-color: rgba(212,165,165,0.2);
    }

    .tab-item:active {
      background: rgba(212,165,165,0.12);
    }

    .tab-item--wa {
      color: #25D366;
    }

    .tab-item--wa .tab-icon {
      background: #25D366;
      border-radius: 14px;
      width: 44px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      box-shadow: 0 2px 8px rgba(37,211,102,0.35);
    }

    .tab-item--wa .tab-label {
      color: #1aa050;
      font-weight: 700;
    }

    .tab-item:not(.tab-item--wa) .tab-icon {
      font-size: 1.3rem;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .tab-icon {
      font-size: 1.3rem;
      line-height: 1;
      transition: transform 0.15s ease;
    }

    .tab-item:active .tab-icon {
      transform: scale(0.9);
    }

    .tab-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-align: center;
      line-height: 1;
    }

    .tab-item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 20%;
      height: 60%;
      width: 1px;
      background: rgba(212,165,165,0.2);
    }
  }
</style>
