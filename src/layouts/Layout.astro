---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = "Viviana Herrera · Pastelería Artesanal en Salto, Buenos Aires",
  description = "Tortas artesanales, postres y mesas dulces para todos tus eventos. Hecha con amor en Salto, Buenos Aires. Pedidos por WhatsApp.",
  // Ruta unificada al logo completo
  image = "/images/logo-completo.webp", 
  url = "https://viviana-herrera-pasteleria.vercel.app",
} = Astro.props;

const siteUrl = "https://viviana-herrera-pasteleria.vercel.app";
const absoluteImage = `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FDFBF7" />
    
    <link rel="icon" type="image/webp" href="/images/logo-completo.webp" />
    <link rel="apple-touch-icon" href="/images/logo-completo.webp" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="pastelería artesanal Salto Buenos Aires, tortas personalizadas Salto, tortas para cumpleaños, tortas infantiles, mesas dulces, postres artesanales, Viviana Herrera pastelería" />
    <meta name="author" content="Viviana Herrera" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="500" />
    <meta property="og:image:height" content="500" />
    <meta property="og:image:alt" content="Viviana Herrera Pastelería - Logo Completo" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Viviana Herrera Pastelería" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    ```

---