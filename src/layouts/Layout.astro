---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = "Viviana Herrera · Pastelería Artesanal en Salto, Buenos Aires",
  description = "Tortas artesanales, postres y mesas dulces para todos tus eventos. Hecha con amor en Salto, Buenos Aires. Pedidos por WhatsApp.",
  // og-image.webp: 1200×630, diseñada para WhatsApp / redes sociales
  image = "/images/og-image.webp",
  url = "https://viviana-herrera-pasteleria.vercel.app",
} = Astro.props;

const siteUrl = "https://viviana-herrera-pasteleria.vercel.app";
const absoluteImage = `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FDFBF7" />
    <link rel="icon" type="image/webp" href="/images/logo-completo.webp" />
    <!-- Fallback PNG para navegadores que no soportan WebP como favicon -->
    <link rel="apple-touch-icon" href="/images/logo-completo.webp" />

    <!-- SEO Primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="pastelería artesanal Salto Buenos Aires, tortas personalizadas Salto, tortas para cumpleaños, tortas infantiles, mesas dulces, postres artesanales, Viviana Herrera pastelería" />
    <meta name="author" content="Viviana Herrera" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Viviana Herrera Pastelería - Tortas y postres artesanales en Salto" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Viviana Herrera Pastelería" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    <!-- Schema.org Local Business -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Bakery",
        "name": "Viviana Herrera Pastelería",
        "url": "https://viviana-herrera-pasteleria.vercel.app",
        "description": "Pastelería artesanal especializada en tortas personalizadas para eventos, postres individuales y mesas dulces en Salto, Buenos Aires.",
        "image": "https://viviana-herrera-pasteleria.vercel.app/images/og-image.webp",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Salto",
          "addressRegion": "Buenos Aires",
          "addressCountry": "AR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "-34.2933",
          "longitude": "-60.2553"
        },
        "telephone": "+5492474453333",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+5492474453333",
          "contactType": "customer service",
          "availableLanguage": "Spanish"
        },
        "openingHours": [
          "Mo-Fr 09:00-19:00",
          "Sa 09:00-14:00"
        ],
        "priceRange": "$$",
        "servesCuisine": ["Pastelería artesanal", "Tortas personalizadas", "Postres"],
        "hasMap": "https://maps.google.com/?q=Salto,Buenos+Aires",
        "sameAs": [
          "https://www.instagram.com/vivhes__/",
          "https://www.facebook.com/profile.php?id=100079233349136"
        ]
      }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --cream: #FDFBF7;
        --grafito: #333333;
        --grafito-light: #666666;
        --rosa-viejo: #D4A5A5;
        --rosa-claro: #F5E6E6;
        --rosa-oscuro: #B8857E;
        --dorado: #C9A96E;
        --dorado-claro: #E8D5B0;
        scroll-behavior: smooth;
      }

      html {
        background-color: var(--cream);
      }

      body {
        font-family: 'Montserrat', system-ui, sans-serif;
        color: var(--grafito);
        background-color: var(--cream);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4 {
        font-family: 'Playfair Display', Georgia, serif;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      /* Scrollbar refinada */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--cream); }
      ::-webkit-scrollbar-thumb { background: var(--rosa-viejo); border-radius: 3px; }

      /* Animaciones de scroll */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.7s ease, transform 0.7s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }
      .reveal-delay-4 { transition-delay: 0.4s; }
    </style>
  </head>

  <body>
    <slot />

    <!-- Scroll reveal script -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
