---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title = "Viviana Herrera · Pastelería Artesanal en Salto, Buenos Aires",
  description = "Tortas artesanales, postres y mesas dulces para todos tus eventos. Hecha con amor en Salto, Buenos Aires. Pedidos por WhatsApp.",
  // Ruta al logo completo para redes sociales
  ogImage = "/images/logo-completo.webp", 
  canonicalURL = Astro.url.href,
} = Astro.props;

// IMPORTANTE: Asegurate que esta URL sea la final de Vercel
const siteURL = 'https://viviana-herrera-pasteleria.vercel.app';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteURL}${ogImage}`;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FDFBF7" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="pastelería artesanal Salto Buenos Aires, tortas personalizadas Salto, tortas para cumpleaños, mesas dulces, Viviana Herrera pastelería" />
    <meta name="author" content="Viviana Herrera" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:secure_url" content={fullOgImage} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Viviana Herrera Pastelería - Salto, Buenos Aires" />
    <meta property="og:site_name" content="Viviana Herrera Pastelería" />
    <meta property="og:locale" content="es_AR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <meta property="og:image" content={fullOgImage} />

    <link rel="icon" type="image/webp" href="/images/logo-completo.webp" />
    <link rel="apple-touch-icon" href="/images/logo-completo.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Bakery",
        "name": "Viviana Herrera Pastelería",
        "description": "Pastelería artesanal especializada en tortas para eventos, postres y mesas dulces",
        "url": "https://viviana-herrera-pasteleria.vercel.app/",
        "telephone": "+5492474453333",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Salto",
          "addressRegion": "Buenos Aires",
          "addressCountry": "AR"
        },
        "priceRange": "$$",
        "image": "https://viviana-herrera-pasteleria.vercel.app/images/logo-completo.webp"
      }
    </script>

    <style is:global>
      :root {
        --cream: #FDFBF7;
        --grafito: #333333;
        --rosa-viejo: #D4A5A5;
        --dorado: #C9A96E;
        --dorado-claro: #E8D5B0;
        scroll-behavior: smooth;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Montserrat', system-ui, sans-serif;
        color: var(--grafito);
        background-color: var(--cream);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3 { font-family: 'Playfair Display', serif; }

      /* Animación de entrada */
      .reveal {
        opacity: 0;
        transform: translateY(25px);
        transition: all 0.8s ease-out;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--cream); }
      ::-webkit-scrollbar-thumb { background: var(--rosa-viejo); border-radius: 3px; }
    </style>
  </head>
  <body>
    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
