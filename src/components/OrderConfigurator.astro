---
const fillings = {
  "Dulce de leche": [
    { id: "ddl", label: "Dulce de leche", emoji: "🍮" },
    { id: "ddl-crocante", label: "Dulce de leche c/ crocante", emoji: "🍮" },
    { id: "ddl-chips", label: "Dulce de leche c/ chips de chocolate", emoji: "🍫" },
    { id: "ddl-marroc", label: "Dulce de leche c/ marroc", emoji: "🍫" },
    { id: "ddl-avellana", label: "Dulce de leche c/ avellana", emoji: "🌰" },
    { id: "ddl-mani", label: "Dulce de leche crema maní", emoji: "🥜" },
    { id: "mousse-ddl", label: "Mousse de dulce de leche", emoji: "🍮" },
  ],
  "Mousses": [
    { id: "mousse-choco", label: "Mousse de chocolate", emoji: "🍫" },
    { id: "mousse-frutilla", label: "Mousse de frutilla", emoji: "🍓" },
  ],
  "Cremas": [
    { id: "tramontana", label: "Crema tramontana", emoji: "🍨" },
    { id: "crema-oreo", label: "Crema Oreo", emoji: "🍪" },
    { id: "crema-durazno", label: "Crema durazno", emoji: "🍑" },
    { id: "crema-frutilla", label: "Crema frutilla", emoji: "🍓" },
    { id: "crema-cafe", label: "Crema café", emoji: "☕" },
    { id: "crema-granizada", label: "Crema granizada", emoji: "❄️" },
    { id: "ganache-frutos", label: "Ganache chocolate blanco c/ frutos rojos", emoji: "🫐" },
    { id: "chocotorta", label: "Crema chocotorta", emoji: "🎂" },
    { id: "bariloche", label: "Crema bariloche", emoji: "🍷" },
  ],
};
---

<section id="pedidos" class="configurator section-padding">
  <div class="config-inner">
    <!-- Header -->
    <div class="section-header reveal">
      <div class="section-tag">Pedido personalizado</div>
      <h2>Armá tu torta<br/><em>ideal</em></h2>
      <p class="section-subtitle">
        Seleccioná el tamaño y los rellenos, y te envío el presupuesto al instante por WhatsApp.
      </p>
    </div>

    <div class="config-card reveal reveal-delay-1">
      <!-- Step 1: Size -->
      <div class="step">
        <div class="step-header">
          <span class="step-number">01</span>
          <div>
            <h3>Elegí el tamaño</h3>
            <p class="step-hint">¿Para cuántas personas es?</p>
          </div>
        </div>

        <div class="size-grid" role="group" aria-label="Tamaño de la torta">
          <label class="size-option" aria-label="1 kilogramo, aproximadamente 8 porciones">
            <input type="radio" name="size" value="1 kg" data-portions="~8 porciones" />
            <div class="size-card">
              <span class="size-icon">🎂</span>
              <strong>1 kg</strong>
              <span class="size-portions">~8 porciones</span>
            </div>
          </label>

          <label class="size-option" aria-label="2 kilogramos, aproximadamente 16 porciones">
            <input type="radio" name="size" value="2 kg" data-portions="~16 porciones" />
            <div class="size-card">
              <span class="size-icon">🎂</span>
              <strong>2 kg</strong>
              <span class="size-portions">~16 porciones</span>
              <span class="size-badge">Más pedido</span>
            </div>
          </label>

          <label class="size-option" aria-label="3 kilogramos, aproximadamente 24 porciones">
            <input type="radio" name="size" value="3 kg" data-portions="~24 porciones" />
            <div class="size-card">
              <span class="size-icon">🎂</span>
              <strong>3 kg</strong>
              <span class="size-portions">~24 porciones</span>
            </div>
          </label>
        </div>
      </div>

      <div class="step-divider"></div>

      <!-- Step 2: Fillings -->
      <div class="step">
        <div class="step-header">
          <span class="step-number">02</span>
          <div>
            <h3>Elegí los rellenos</h3>
            <p class="step-hint">Podés elegir <strong>hasta 2 rellenos</strong> para combinar las capas</p>
          </div>
          <span class="filling-counter" id="filling-counter">0 / 2 seleccionados</span>
        </div>

        <div class="fillings-container" id="fillings-container">
          {Object.entries(fillings).map(([category, items]) => (
            <div class="filling-category">
              <h4 class="filling-cat-title">{category}</h4>
              <div class="fillings-grid">
                {items.map(item => (
                  <label class="filling-option" aria-label={item.label}>
                    <input
                      type="checkbox"
                      name="filling"
                      value={item.label}
                      id={item.id}
                      class="filling-check"
                    />
                    <div class="filling-card">
                      <span class="filling-emoji">{item.emoji}</span>
                      <span class="filling-label">{item.label}</span>
                      <span class="filling-check-icon">✓</span>
                    </div>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </div>

        <p class="selection-warning" id="selection-warning" hidden>
          ⚠️ Podés elegir hasta 2 rellenos
        </p>
      </div>

      <div class="step-divider"></div>

      <!-- Step 3: Summary + CTA -->
      <div class="step">
        <div class="step-header">
          <span class="step-number">03</span>
          <div>
            <h3>Confirmá tu pedido</h3>
            <p class="step-hint">Revisá el resumen y envialo por WhatsApp</p>
          </div>
        </div>

        <div class="summary-box" id="summary-box">
          <div class="summary-row">
            <span class="summary-label">Tamaño:</span>
            <span class="summary-value" id="summary-size">—</span>
          </div>
          <div class="summary-row">
            <span class="summary-label">Rellenos:</span>
            <span class="summary-value" id="summary-fillings">—</span>
          </div>
          <div class="summary-row">
            <span class="summary-label">Porciones aprox.:</span>
            <span class="summary-value" id="summary-portions">—</span>
          </div>
        </div>

        <button
          id="wa-btn"
          class="wa-btn"
          disabled
          aria-label="Enviar pedido por WhatsApp a Viviana"
        >
          💬 Enviar pedido por WhatsApp
        </button>
        <p class="wa-hint">Te responderé a la brevedad con el presupuesto 💬</p>
      </div>
    </div>
  </div>
</section>

<script>
  const MAX_FILLINGS = 2;
  const WA_NUMBER = "5492474453333";

  let selectedSize = '';
  let selectedPortions = '';
  const selectedFillings: string[] = [];

  const summarySize = document.getElementById('summary-size')!;
  const summaryFillings = document.getElementById('summary-fillings')!;
  const summaryPortions = document.getElementById('summary-portions')!;
  const waBtn = document.getElementById('wa-btn') as HTMLButtonElement;
  const warning = document.getElementById('selection-warning')!;

  // Actualiza el estado bloqueado/desbloqueado de todas las opciones
  function updateFillingLock() {
    const maxReached = selectedFillings.length >= MAX_FILLINGS;
    document.querySelectorAll('.filling-option').forEach((opt) => {
      const input = opt.querySelector('input') as HTMLInputElement;
      const card = opt.querySelector('.filling-card') as HTMLElement;
      if (!input || !card) return;

      if (maxReached && !input.checked) {
        // Bloquear opciones no seleccionadas
        input.disabled = true;
        card.classList.add('filling-card--locked');
      } else {
        // Desbloquear todo cuando hay menos de 2
        input.disabled = false;
        card.classList.remove('filling-card--locked');
      }
    });

    // Mostrar/ocultar contador
    const counter = document.getElementById('filling-counter')!;
    if (counter) {
      counter.textContent = `${selectedFillings.length} / ${MAX_FILLINGS} seleccionados`;
      counter.classList.toggle('filling-counter--full', maxReached);
    }
  }

  function updateSummary() {
    summarySize.textContent = selectedSize || '—';
    summaryFillings.textContent = selectedFillings.length > 0 ? selectedFillings.join(' + ') : '—';
    summaryPortions.textContent = selectedPortions || '—';

    const ready = selectedSize && selectedFillings.length > 0;
    waBtn.disabled = !ready;

    if (ready) {
      const fillingText = selectedFillings.join(' y ');
      const msg = `Hola Viviana! 🎂 Quisiera pedir un presupuesto para una torta de *${selectedSize}* con rellenos de *${fillingText}*. ¿Me podés indicar el costo y disponibilidad? ¡Muchas gracias!`;
      waBtn.onclick = () => window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
    }
  }

  // Tamaños
  document.querySelectorAll('input[name="size"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      selectedSize = input.value;
      selectedPortions = input.getAttribute('data-portions') || '';
      updateSummary();
    });
  });

  // Rellenos
  document.querySelectorAll('.filling-check').forEach(cb => {
    cb.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      const val = input.value;

      if (input.checked) {
        if (selectedFillings.length >= MAX_FILLINGS) {
          input.checked = false;
          return;
        }
        selectedFillings.push(val);
      } else {
        const idx = selectedFillings.indexOf(val);
        if (idx > -1) selectedFillings.splice(idx, 1);
      }

      updateFillingLock();
      updateSummary();
    });
  });

  // Init
  updateFillingLock();
</script>

<style>
  .configurator {
    background: linear-gradient(180deg, #F9F3EF 0%, #FDFBF7 100%);
  }

  .section-padding { padding: 6rem 1.5rem; }

  .config-inner { max-width: 860px; margin: 0 auto; }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rosa-viejo);
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-tag::before, .section-tag::after {
    content: '';
    width: 30px;
    height: 1px;
    background: var(--rosa-viejo);
    opacity: 0.4;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.2;
    color: var(--grafito);
    margin-bottom: 0.75rem;
  }

  h2 em { font-style: italic; color: var(--rosa-oscuro); }

  .section-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    color: #888;
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Card */
  .config-card {
    background: white;
    border-radius: 24px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.07);
    border: 1px solid rgba(212,165,165,0.15);
    overflow: hidden;
  }

  .step {
    padding: 2rem 2.5rem;
  }

  .step-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,165,165,0.3), transparent);
  }

  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .step-number {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--rosa-claro);
    line-height: 1;
    flex-shrink: 0;
    min-width: 2.5rem;
  }

  .step-header h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--grafito);
    margin-bottom: 0.2rem;
  }

  .step-hint {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    color: #aaa;
  }

  /* Sizes */
  .size-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .size-option input[type="radio"] { display: none; }

  .size-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1.25rem 1rem;
    border: 2px solid rgba(212,165,165,0.25);
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    text-align: center;
    background: #FDFBF7;
  }

  .size-card:hover {
    border-color: var(--rosa-viejo);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212,165,165,0.2);
  }

  .size-option input:checked ~ .size-card {
    border-color: var(--rosa-viejo);
    background: var(--rosa-claro);
    box-shadow: 0 4px 16px rgba(212,165,165,0.3);
  }

  .size-icon { font-size: 1.8rem; }
  .size-card strong { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--grafito); }
  .size-portions { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; color: #aaa; }

  .size-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--dorado);
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    white-space: nowrap;
  }

  /* Fillings */
  .filling-category { margin-bottom: 1.5rem; }

  .filling-cat-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rosa-viejo);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .filling-cat-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(212,165,165,0.2);
  }

  .fillings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.6rem;
  }

  .filling-option input { display: none; }

  .filling-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid rgba(212,165,165,0.2);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: #FDFBF7;
    position: relative;
  }

  .filling-card:hover {
    border-color: var(--rosa-viejo);
    background: white;
  }

  .filling-option input:checked ~ .filling-card {
    border-color: var(--rosa-viejo);
    background: var(--rosa-claro);
  }

  .filling-emoji { font-size: 1rem; flex-shrink: 0; }

  .filling-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    color: var(--grafito);
    line-height: 1.3;
    flex: 1;
  }

  .filling-check-icon {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--rosa-oscuro);
    opacity: 0;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .filling-option input:checked ~ .filling-card .filling-check-icon { opacity: 1; }

  /* Estado bloqueado — visualmente apagado y no clickeable */
  .filling-card--locked {
    opacity: 0.38;
    cursor: not-allowed;
    filter: grayscale(0.4);
    background: #f0ece8 !important;
    border-color: rgba(212,165,165,0.12) !important;
    transform: none !important;
  }

  .filling-card--locked:hover {
    border-color: rgba(212,165,165,0.12) !important;
    background: #f0ece8 !important;
    transform: none !important;
    box-shadow: none !important;
  }

  /* Contador de rellenos seleccionados */
  .filling-counter {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    color: #aaa;
    background: #f0ece8;
    padding: 0.25rem 0.7rem;
    border-radius: 50px;
    white-space: nowrap;
    align-self: flex-start;
    margin-left: auto;
    transition: all 0.2s;
  }

  .filling-counter--full {
    background: var(--rosa-claro);
    color: var(--rosa-oscuro);
  }

  .selection-warning {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    color: var(--rosa-oscuro);
    background: var(--rosa-claro);
    padding: 0.6rem 1rem;
    border-radius: 8px;
    margin-top: 0.75rem;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Summary */
  .summary-box {
    background: #FDFBF7;
    border: 1px solid rgba(212,165,165,0.2);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .summary-row {
    display: flex;
    gap: 0.75rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
  }

  .summary-label {
    color: #aaa;
    min-width: 130px;
    flex-shrink: 0;
  }

  .summary-value {
    color: var(--grafito);
    font-weight: 500;
  }

  /* WhatsApp button */
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: white;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(37,211,102,0.35);
    width: 100%;
    justify-content: center;
  }

  .wa-btn:hover:not(:disabled) {
    background: #20b557;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(37,211,102,0.45);
  }

  .wa-btn:disabled {
    background: #ccc;
    box-shadow: none;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .wa-hint {
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    color: #aaa;
    margin-top: 0.75rem;
  }

  @media (max-width: 600px) {
    /* Padding generoso para dedos */
    .step { padding: 1.5rem 1.25rem; }

    /* Step header: apilar en columna para evitar texto estrecho */
    .step-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    /* Número grande decorativo más compacto */
    .step-number {
      font-size: 1.4rem;
      min-width: auto;
    }

    /* Contador al ancho completo */
    .filling-counter {
      margin-left: 0;
      align-self: stretch;
      text-align: center;
    }

    /* Título del paso más grande — legibilidad */
    .step-header h3 {
      font-size: 1.1rem;
    }

    /* Hint más legible */
    .step-hint {
      font-size: 0.82rem;
      line-height: 1.5;
    }

    /* Tamaños en una fila de 3 compacta */
    .size-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }
    .size-card { padding: 0.9rem 0.4rem; }
    .size-card strong { font-size: 1rem; }
    .size-icon { font-size: 1.4rem; }

    /* Rellenos en columna única — área táctil máxima */
    .fillings-grid { grid-template-columns: 1fr; gap: 0.5rem; }

    /* Cards de relleno más altas y cómodas */
    .filling-card {
      padding: 0.8rem 1rem;
      min-height: 48px;
    }
    .filling-label { font-size: 0.85rem; }
    .filling-emoji { font-size: 1.2rem; }

    /* Resumen más legible */
    .summary-row { font-size: 0.88rem; }
    .summary-label { min-width: 110px; }

    /* Botón WA bien grande */
    .wa-btn {
      font-size: 1rem;
      padding: 1.1rem 1.5rem;
      min-height: 56px;
    }

    /* Categoría de rellenos */
    .filling-cat-title { font-size: 0.72rem; }
  }
</style>
