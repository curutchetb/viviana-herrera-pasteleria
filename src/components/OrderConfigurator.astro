---
const fillings = {
  "Clásicos": [
    { id: "ddl-chispas", label: "Dulce de leche con chispas", emoji: "🍫" },
    { id: "crema-durazno", label: "Crema de durazno", emoji: "🍑" },
    { id: "crema-frutilla", label: "Crema de frutilla", emoji: "🍓" },
  ],
  "Chocolates": [
    { id: "mousse-choco", label: "Mousse de chocolate", emoji: "🍫" },
    { id: "crema-bariloche", label: "Crema Bariloche (con licor)", emoji: "🍷" },
  ],
  "Premium / Tendencia": [
    { id: "nutella-ddl", label: "Nutella (D. de leche con avellana)", emoji: "🌰" },
    { id: "crema-oreo", label: "Crema Oreo", emoji: "🍪" },
    { id: "tramontana", label: "Tramontana", emoji: "🍨" },
    { id: "chocotorta", label: "Crema Chocotorta", emoji: "🎂" },
    { id: "crema-cafe", label: "Crema de café", emoji: "☕" },
    { id: "crema-granizada", label: "Crema granizada", emoji: "❄️" },
    { id: "crema-limon", label: "Crema de limón", emoji: "🍋" },
  ],
};
---

<section id="pedidos" class="configurator section-padding">
  <div class="config-inner">
    <!-- Header -->
    <div class="section-header reveal">
      <div class="section-tag">Pedido personalizado</div>
      <h2>Armá tu torta<br/><em>ideal</em></h2>
      <p class="section-subtitle">
        Seleccioná el tamaño y los rellenos, y te envío el presupuesto al instante por WhatsApp.
      </p>
    </div>

    <div class="config-card reveal reveal-delay-1">
      <!-- Step 1: Size -->
      <div class="step">
        <div class="step-header">
          <span class="step-number">01</span>
          <div>
            <h3>Elegí el tamaño</h3>
            <p class="step-hint">¿Para cuántas personas es?</p>
          </div>
        </div>

        <div class="size-grid" role="group" aria-label="Tamaño de la torta">
          <label class="size-option" aria-label="1 kilogramo, aproximadamente 8 porciones">
            <input type="radio" name="size" value="1 kg" data-portions="~8 porciones" />
            <div class="size-card">
              <span class="size-icon">🎂</span>
              <strong>1 kg</strong>
              <span class="size-portions">~8 porciones</span>
            </div>
          </label>

          <label class="size-option" aria-label="2 kilogramos, aproximadamente 16 porciones">
            <input type="radio" name="size" value="2 kg" data-portions="~16 porciones" />
            <div class="size-card">
              <span class="size-icon">🎂</span>
              <strong>2 kg</strong>
              <span class="size-portions">~16 porciones</span>
              <span class="size-badge">Más pedido</span>
            </div>
          </label>

          <label class="size-option" aria-label="3 kilogramos, aproximadamente 24 porciones">
            <input type="radio" name="size" value="3 kg" data-portions="~24 porciones" />
            <div class="size-card">
              <span class="size-icon">🎂</span>
              <strong>3 kg</strong>
              <span class="size-portions">~24 porciones</span>
            </div>
          </label>
        </div>
      </div>

      <div class="step-divider"></div>

      <!-- Step 2: Fillings -->
      <div class="step">
        <div class="step-header">
          <span class="step-number">02</span>
          <div>
            <h3>Elegí los rellenos</h3>
            <p class="step-hint">Podés elegir hasta 2 rellenos para combinar las capas</p>
          </div>
        </div>

        <div class="fillings-container" id="fillings-container">
          {Object.entries(fillings).map(([category, items]) => (
            <div class="filling-category">
              <h4 class="filling-cat-title">{category}</h4>
              <div class="fillings-grid">
                {items.map(item => (
                  <label class="filling-option" aria-label={item.label}>
                    <input
                      type="checkbox"
                      name="filling"
                      value={item.label}
                      id={item.id}
                      class="filling-check"
                    />
                    <div class="filling-card">
                      <span class="filling-emoji">{item.emoji}</span>
                      <span class="filling-label">{item.label}</span>
                      <span class="filling-check-icon">✓</span>
                    </div>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </div>

        <p class="selection-warning" id="selection-warning" hidden>
          ⚠️ Podés elegir hasta 2 rellenos
        </p>
      </div>

      <div class="step-divider"></div>

      <!-- Step 3: Summary + CTA -->
      <div class="step">
        <div class="step-header">
          <span class="step-number">03</span>
          <div>
            <h3>Confirmá tu pedido</h3>
            <p class="step-hint">Revisá el resumen y envialo por WhatsApp</p>
          </div>
        </div>

        <div class="summary-box" id="summary-box">
          <div class="summary-row">
            <span class="summary-label">Tamaño:</span>
            <span class="summary-value" id="summary-size">—</span>
          </div>
          <div class="summary-row">
            <span class="summary-label">Rellenos:</span>
            <span class="summary-value" id="summary-fillings">—</span>
          </div>
          <div class="summary-row">
            <span class="summary-label">Porciones aprox.:</span>
            <span class="summary-value" id="summary-portions">—</span>
          </div>
        </div>

        <button
          id="wa-btn"
          class="wa-btn"
          disabled
          aria-label="Enviar pedido por WhatsApp a Viviana"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Enviar pedido por WhatsApp
        </button>
        <p class="wa-hint">Te responderé a la brevedad con el presupuesto 💬</p>
      </div>
    </div>
  </div>
</section>

<script>
  const MAX_FILLINGS = 2;
  const WA_NUMBER = "5492474453333";

  let selectedSize = '';
  let selectedPortions = '';
  const selectedFillings: string[] = [];

  const summarySize = document.getElementById('summary-size')!;
  const summaryFillings = document.getElementById('summary-fillings')!;
  const summaryPortions = document.getElementById('summary-portions')!;
  const waBtn = document.getElementById('wa-btn') as HTMLButtonElement;
  const warning = document.getElementById('selection-warning')!;

  function updateSummary() {
    summarySize.textContent = selectedSize || '—';
    summaryFillings.textContent = selectedFillings.length > 0 ? selectedFillings.join(' + ') : '—';
    summaryPortions.textContent = selectedPortions || '—';

    const ready = selectedSize && selectedFillings.length > 0;
    waBtn.disabled = !ready;

    if (ready) {
      const fillingText = selectedFillings.join(' y ');
      const msg = `Hola Viviana! 🎂 Quisiera pedir un presupuesto para una torta de *${selectedSize}* con rellenos de *${fillingText}*. ¿Me podés indicar el costo y disponibilidad? ¡Muchas gracias!`;
      waBtn.onclick = () => window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
    }
  }

  // Size radios
  document.querySelectorAll('input[name="size"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      selectedSize = input.value;
      selectedPortions = input.getAttribute('data-portions') || '';
      updateSummary();
    });
  });

  // Filling checkboxes
  document.querySelectorAll('.filling-check').forEach(cb => {
    cb.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      const val = input.value;

      if (input.checked) {
        if (selectedFillings.length >= MAX_FILLINGS) {
          input.checked = false;
          warning.removeAttribute('hidden');
          setTimeout(() => warning.setAttribute('hidden', ''), 3000);
          return;
        }
        selectedFillings.push(val);
      } else {
        const idx = selectedFillings.indexOf(val);
        if (idx > -1) selectedFillings.splice(idx, 1);
      }

      updateSummary();
    });
  });
</script>

<style>
  .configurator {
    background: linear-gradient(180deg, #F9F3EF 0%, #FDFBF7 100%);
  }

  .section-padding { padding: 6rem 1.5rem; }

  .config-inner { max-width: 860px; margin: 0 auto; }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rosa-viejo);
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-tag::before, .section-tag::after {
    content: '';
    width: 30px;
    height: 1px;
    background: var(--rosa-viejo);
    opacity: 0.4;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.2;
    color: var(--grafito);
    margin-bottom: 0.75rem;
  }

  h2 em { font-style: italic; color: var(--rosa-oscuro); }

  .section-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    color: #888;
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Card */
  .config-card {
    background: white;
    border-radius: 24px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.07);
    border: 1px solid rgba(212,165,165,0.15);
    overflow: hidden;
  }

  .step {
    padding: 2rem 2.5rem;
  }

  .step-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,165,165,0.3), transparent);
  }

  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .step-number {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--rosa-claro);
    line-height: 1;
    flex-shrink: 0;
    min-width: 2.5rem;
  }

  .step-header h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--grafito);
    margin-bottom: 0.2rem;
  }

  .step-hint {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    color: #aaa;
  }

  /* Sizes */
  .size-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .size-option input[type="radio"] { display: none; }

  .size-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1.25rem 1rem;
    border: 2px solid rgba(212,165,165,0.25);
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    text-align: center;
    background: #FDFBF7;
  }

  .size-card:hover {
    border-color: var(--rosa-viejo);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212,165,165,0.2);
  }

  .size-option input:checked ~ .size-card {
    border-color: var(--rosa-viejo);
    background: var(--rosa-claro);
    box-shadow: 0 4px 16px rgba(212,165,165,0.3);
  }

  .size-icon { font-size: 1.8rem; }
  .size-card strong { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--grafito); }
  .size-portions { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; color: #aaa; }

  .size-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--dorado);
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    white-space: nowrap;
  }

  /* Fillings */
  .filling-category { margin-bottom: 1.5rem; }

  .filling-cat-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rosa-viejo);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .filling-cat-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(212,165,165,0.2);
  }

  .fillings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.6rem;
  }

  .filling-option input { display: none; }

  .filling-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid rgba(212,165,165,0.2);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: #FDFBF7;
    position: relative;
  }

  .filling-card:hover {
    border-color: var(--rosa-viejo);
    background: white;
  }

  .filling-option input:checked ~ .filling-card {
    border-color: var(--rosa-viejo);
    background: var(--rosa-claro);
  }

  .filling-emoji { font-size: 1rem; flex-shrink: 0; }

  .filling-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    color: var(--grafito);
    line-height: 1.3;
    flex: 1;
  }

  .filling-check-icon {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--rosa-oscuro);
    opacity: 0;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .filling-option input:checked ~ .filling-card .filling-check-icon { opacity: 1; }

  .selection-warning {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    color: var(--rosa-oscuro);
    background: var(--rosa-claro);
    padding: 0.6rem 1rem;
    border-radius: 8px;
    margin-top: 0.75rem;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Summary */
  .summary-box {
    background: #FDFBF7;
    border: 1px solid rgba(212,165,165,0.2);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .summary-row {
    display: flex;
    gap: 0.75rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
  }

  .summary-label {
    color: #aaa;
    min-width: 130px;
    flex-shrink: 0;
  }

  .summary-value {
    color: var(--grafito);
    font-weight: 500;
  }

  /* WhatsApp button */
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: white;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(37,211,102,0.35);
    width: 100%;
    justify-content: center;
  }

  .wa-btn:hover:not(:disabled) {
    background: #20b557;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(37,211,102,0.45);
  }

  .wa-btn:disabled {
    background: #ccc;
    box-shadow: none;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .wa-hint {
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    color: #aaa;
    margin-top: 0.75rem;
  }

  @media (max-width: 600px) {
    .step { padding: 1.5rem; }
    .size-grid { grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
    .fillings-grid { grid-template-columns: 1fr; }
    .size-card { padding: 1rem 0.5rem; }
  }
</style>
