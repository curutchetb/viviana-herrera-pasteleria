---
---

<section id="nosotros" class="about section-padding">
  <div class="about-inner">
    <!-- Decorative element -->
    <div class="section-tag reveal">Sobre mí</div>

    <div class="about-grid">
      <!-- Photo -->
      <div class="photo-col reveal">
        <div class="photo-frame">
          <img
            src="/images/viviana-perfil.webp"
            alt="Viviana Herrera, pastelera artesanal en Salto, Buenos Aires"
            loading="lazy"
            class="photo"
            width="380"
            height="380"
          />
          <!-- Decorative ring -->
          <div class="photo-ring"></div>
          <!-- Accent badge -->
          <div class="photo-badge">
            <span class="badge-icon">🌸</span>
            <span>Hecho con amor</span>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="text-col">
        <h2 class="reveal">
          Una pasión hecha<br/>
          <em>torta a torta</em>
        </h2>

        <div class="divider reveal reveal-delay-1"></div>

        <p class="reveal reveal-delay-1">
          Hola, soy <strong>Viviana Herrera</strong>, pastelera artesanal radicada en Salto, Buenos Aires.
          Mi amor por la repostería empezó en la cocina de mi hogar, entre recetas heredadas y el
          deseo de hacer feliz a cada persona en sus momentos especiales.
        </p>

        <p class="reveal reveal-delay-2">
          Hoy me especializo en <strong>tortas personalizadas, postres individuales y mesas dulces</strong>
          para todo tipo de eventos: cumpleaños infantiles, celebraciones de adultos, casamientos,
          comuniones y cualquier ocasión que merezca algo dulce y memorable.
        </p>

        <p class="reveal reveal-delay-3">
          Cada creación está pensada desde el primer bocado hasta el último detalle visual.
          Trabajo con ingredientes seleccionados y mucho cariño — porque creo que lo artesanal
          se nota, y que tu evento merece algo único.
        </p>

        <div class="about-features reveal reveal-delay-4">
          <div class="feature">
            <span class="feature-icon">🎂</span>
            <div>
              <strong>Tortas personalizadas</strong>
              <span>Infantiles, temáticas y para adultos</span>
            </div>
          </div>
          <div class="feature">
            <span class="feature-icon">🍮</span>
            <div>
              <strong>Postresitos individuales</strong>
              <span>Perfectos para eventos y mesas dulces</span>
            </div>
          </div>
          <div class="feature">
            <span class="feature-icon">🍓</span>
            <div>
              <strong>Tartas frutales</strong>
              <span>Lemon pie, tartas con frutas frescas</span>
            </div>
          </div>
        </div>

        <a
          href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Vi%20tu%20historia%20en%20la%20web%20y%20quisiera%20consultarte"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-contact reveal reveal-delay-4"
        >
          Consultarme directamente
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: #FDFBF7;
    position: relative;
    overflow: hidden;
  }

  /* Subtle grain texture */
  .about::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .section-padding {
    padding: 6rem 1.5rem;
  }

  .about-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .section-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rosa-viejo);
    margin-bottom: 3rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-tag::before, .section-tag::after {
    content: '';
    height: 1px;
    background: var(--rosa-viejo);
    opacity: 0.4;
  }
  .section-tag::before { width: 40px; }
  .section-tag::after { flex: 1; max-width: 80px; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  /* Photo */
  .photo-col {
    display: flex;
    justify-content: center;
  }

  .photo-frame {
    position: relative;
    width: 320px;
    height: 320px;
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    position: relative;
    z-index: 1;
    filter: grayscale(10%) contrast(1.02);
    transition: filter 0.4s ease;
  }

  .photo-frame:hover .photo {
    filter: grayscale(0%) contrast(1.05);
  }

  .photo-ring {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1.5px dashed var(--dorado);
    opacity: 0.6;
    animation: spin 30s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .photo-badge {
    position: absolute;
    bottom: 10px;
    right: -10px;
    background: white;
    border: 1px solid var(--rosa-claro);
    border-radius: 50px;
    padding: 0.4rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--grafito);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    z-index: 2;
    white-space: nowrap;
  }

  /* Text */
  .text-col h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.2;
    color: var(--grafito);
    margin-bottom: 1.5rem;
  }

  .text-col h2 em {
    font-style: italic;
    color: var(--rosa-oscuro);
  }

  .divider {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--dorado), transparent);
    margin-bottom: 1.5rem;
  }

  .text-col p {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.92rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 1rem;
  }

  .text-col p strong { color: var(--grafito); font-weight: 600; }

  .about-features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--rosa-claro);
    border-radius: 16px;
    border-left: 3px solid var(--rosa-viejo);
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .feature-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .feature div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .feature strong {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--grafito);
  }

  .feature span {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.76rem;
    color: #888;
  }

  .btn-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--rosa-oscuro);
    text-decoration: none;
    letter-spacing: 0.05em;
    border-bottom: 1.5px solid var(--rosa-viejo);
    padding-bottom: 2px;
    transition: all 0.2s ease;
  }

  .btn-contact:hover {
    color: var(--grafito);
    border-color: var(--grafito);
    gap: 0.75rem;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .photo-frame { width: 260px; height: 260px; }
  }
</style>
