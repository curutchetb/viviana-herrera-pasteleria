---
// Hero.astro v3 — Fondo Extendido
// Colores extraídos de logo-bg.webp:  top #d0c19f  |  sides #bca08e  |  bottom #c2ac9b
---

<section id="inicio" class="hero" aria-label="Viviana Herrera Pastelería">

  <div class="hero-bg" aria-hidden="true">
    <img
      src="/images/logo-bg.webp"
      alt=""
      class="hero-img"
      loading="eager"
      fetchpriority="high"
      width="512"
      height="276"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">

    <div class="hero-top reveal">
      <p class="hero-location">
        <svg width="10" height="13" viewBox="0 0 10 13" fill="none" aria-hidden="true">
          <path d="M5 0C2.24 0 0 2.24 0 5c0 3.75 5 8 5 8s5-4.25 5-8c0-2.76-2.24-5-5-5zm0 6.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" fill="currentColor"/>
        </svg>
        Salto, Buenos Aires
      </p>
      <h1 class="hero-tagline">
        Tortas artesanales&thinsp;&middot;&thinsp;Postres&thinsp;&middot;&thinsp;Mesas&nbsp;dulces
      </h1>
    </div>

    <div class="hero-logo-spacer" aria-hidden="true"></div>

    <div class="hero-bottom reveal reveal-delay-2">
      <div class="hero-actions">
        <a
          href="https://wa.me/5491100000000?text=Hola%20Viviana!%20Vi%20tu%20web%20y%20me%20gustar%C3%ADa%20consultar%20sobre%20un%20pedido"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          aria-label="Hacer un pedido por WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hacer un pedido
        </a>
        <a href="#galeria" class="btn-secondary">Ver creaciones</a>
      </div>
      <div class="scroll-hint" aria-hidden="true">
        <span>Deslizá para conocer más</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </div>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════
     FONDO EXTENDIDO
     Gradiente radial que imita los colores de borde de
     logo-bg.webp. Cuando la imagen no llega a los bordes
     (cualquier viewport), este fondo la "prolonga" de forma
     imperceptible. Adiós franjas negras.
  ═══════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
    background:
      radial-gradient(
        ellipse 130% 90% at 50% 48%,
        #cec0ae 0%,
        #baa38e 45%,
        #927460 80%,
        #6e4e3c 100%
      );
  }

  /* ── IMAGEN ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* 42% Y: logo circular queda en el tercio superior-central */
    object-position: center 42%;
    /* Fade suave en los bordes → se funde con el fondo extendido */
    mask-image: radial-gradient(
      ellipse 95% 90% at 50% 50%,
      black 55%,
      rgba(0,0,0,0.6) 75%,
      transparent 100%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 95% 90% at 50% 50%,
      black 55%,
      rgba(0,0,0,0.6) 75%,
      transparent 100%
    );
  }

  /* ── OVERLAY — gradiente vertical para legibilidad ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(20, 11, 6, 0.62)  0%,
      rgba(20, 11, 6, 0.22) 22%,
      rgba(20, 11, 6, 0.04) 38%,
      rgba(20, 11, 6, 0.04) 60%,
      rgba(20, 11, 6, 0.28) 76%,
      rgba(20, 11, 6, 0.68) 100%
    );
  }

  /* ── CONTENIDO ── */
  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    justify-content: space-between;
    /* 110px = navbar (~75px) + aire visual generoso (35px)
       env() = margen de notch en iPhones                   */
    padding-top: calc(110px + env(safe-area-inset-top, 0px));
    padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
  }

  /* ── TEXTOS SEO ── */
  .hero-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
  }

  .hero-location {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #EAD9B5;
    text-shadow: 0 1px 6px rgba(0,0,0,0.85), 0 0 16px rgba(0,0,0,0.5);
  }

  .hero-tagline {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(0.66rem, 1.9vw, 0.86rem);
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(253, 251, 247, 0.90);
    text-shadow: 0 1px 10px rgba(0,0,0,0.95), 0 0 24px rgba(0,0,0,0.6);
    line-height: 1.65;
    margin: 0;
    padding: 0;
  }

  /* ── ESPACIADOR (zona visual del logo) ── */
  .hero-logo-spacer {
    flex: 1;
    min-height: 28px;
  }

  /* ── ZONA BOTONES ── */
  .hero-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: #fff;
    padding: 0.85rem 1.75rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 4px 22px rgba(37,211,102,0.50);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: #20b557;
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(37,211,102,0.60);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(253,251,247,0.10);
    color: #FDFBF7;
    padding: 0.85rem 1.75rem;
    border-radius: 50px;
    border: 1.5px solid rgba(253,251,247,0.55);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    white-space: nowrap;
  }

  .btn-secondary:hover {
    background: rgba(253,251,247,0.20);
    border-color: rgba(253,251,247,0.9);
    transform: translateY(-2px);
  }

  /* ── SCROLL HINT ── */
  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(253,251,247,0.42);
    font-size: 0.62rem;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    animation: hint-bounce 2.4s ease-in-out infinite;
  }

  @keyframes hint-bounce {
    0%,100% { transform: translateY(0);    opacity: 0.42; }
    50%      { transform: translateY(7px); opacity: 0.68; }
  }

  /* ═══════════════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════════════ */

  /* Mobile portrait ≤ 600px */
  @media (max-width: 600px) {
    .hero-content {
      padding-top: calc(92px + env(safe-area-inset-top, 0px));
      padding-bottom: calc(1.75rem + env(safe-area-inset-bottom, 0px));
    }
    /* Sin mask en mobile: la imagen cubre bien con cover
       y el fondo extendido maneja los gaps */
    .hero-img {
      object-position: center 40%;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .btn-primary,
    .btn-secondary {
      width: 100%;
      justify-content: center;
    }
    .hero-tagline {
      font-size: 0.64rem;
      letter-spacing: 0.17em;
    }
    .hero-logo-spacer { min-height: 16px; }
  }

  /* Mobile landscape */
  @media (max-width: 900px) and (orientation: landscape) {
    .hero-content {
      padding-top: calc(68px + env(safe-area-inset-top, 0px));
    }
    .hero-logo-spacer { min-height: 8px; }
    .scroll-hint { display: none; }
  }

  /* Tablet 601–900px */
  @media (min-width: 601px) and (max-width: 900px) {
    .hero-content {
      padding-top: calc(100px + env(safe-area-inset-top, 0px));
    }
  }

  /* Desktop grande > 1400px */
  @media (min-width: 1400px) {
    .hero-content { padding-top: 124px; }
    .hero-tagline { font-size: 0.9rem; }
  }
</style>