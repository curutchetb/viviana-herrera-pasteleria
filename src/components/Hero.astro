---
// src/components/Hero.astro
// IMPORTANTE: Ya no importamos el componente Logo porque queremos usar el fondo con el logo integrado.
---

<section id="inicio" class="hero">
  <div class="hero-bg">
    <img
      src="/images/logo-bg.webp"  alt="Mesa de dulces artesanales Viviana Herrera"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    
    <p class="hero-tagline reveal reveal-delay-1">
      Tortas artesanales · Postres · Mesas dulces
    </p>

    <p class="hero-location reveal reveal-delay-2">
      📍 Salto, Buenos Aires
    </p>

    <div class="hero-actions reveal reveal-delay-3">
      <a
        href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Vi%20tu%20web%20y%20me%20gustar%C3%ADa%20consultar%20sobre%20un%20pedido"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hacer un pedido
      </a>
      <a href="#galeria" class="btn-secondary">Ver creaciones</a>
    </div>

    <div class="scroll-hint reveal reveal-delay-4">
      <span>Deslizá para conocer más</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </div>
  </div>
</section>

<style>
  /* Aquí va todo el CSS que ya tenías, se mantiene igual */
  .hero { position: relative; min-height: 100svh; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; }
  /* Un degradado sutil para oscurecer la imagen y que el texto resalte */
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(160deg, rgba(51,33,28,0.55) 0%, rgba(51,33,28,0.4) 50%, rgba(201,169,110,0.2) 100%); }
  .hero-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; padding: 2rem 1.5rem; max-width: 640px; margin: 0 auto; }
  .hero-tagline { font-family: 'Montserrat', sans-serif; font-size: clamp(0.8rem, 2.5vw, 1rem); letter-spacing: 0.3em; color: #E8D5B0; text-transform: uppercase; }
  .hero-location { font-family: 'Montserrat', sans-serif; font-size: 0.85rem; color: rgba(253,251,247,0.8); }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
  .btn-primary { background: #25D366; color: white; padding: 0.85rem 1.8rem; border-radius: 50px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; }
  .btn-secondary { background: transparent; color: #FDFBF7; padding: 0.85rem 1.8rem; border-radius: 50px; border: 1.5px solid rgba(253,251,247,0.5); text-decoration: none; backdrop-filter: blur(4px); }
  .scroll-hint { margin-top: 1.5rem; color: rgba(253,251,247,0.5); font-size: 0.7rem; display: flex; flex-direction: column; align-items: center; animation: bounce 2s infinite; }
  @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(6px); } }
</style>