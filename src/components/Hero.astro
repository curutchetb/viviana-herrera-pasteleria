---
// src/components/Hero.astro
---

<section id="inicio" class="hero">
  <div class="hero-bg">
    <img
      src="/images/logo-bg.webp" 
      alt="Pastelería Viviana Herrera"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="hero-header">
       <p class="hero-location reveal">📍 Salto, Buenos Aires</p>
       <h1 class="hero-titles reveal">
         TORTAS ARTESANALES • POSTRES • MESAS DULCES
       </h1>
    </div>

    <div class="hero-spacer"></div>

    <div class="hero-footer">
      <div class="hero-actions reveal">
        <a href="https://wa.me/5492474453333" target="_blank" class="btn-primary">
          Hacer un pedido
        </a>
        <a href="#galeria" class="btn-secondary">Ver creaciones</a>
      </div>

      <div class="scroll-hint reveal">
        <span>Deslizá para conocer más</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { 
    position: relative; 
    height: 100vh; 
    display: flex; 
    overflow: hidden; 
  }

  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.65); }
  
  .hero-overlay { 
    position: absolute; 
    inset: 0; 
    background: radial-gradient(circle, rgba(51,33,28,0.1) 0%, rgba(51,33,28,0.5) 100%); 
  }

  .hero-content { 
    position: relative; 
    z-index: 1; 
    width: 100%;
    height: 100vh;
    display: flex; 
    flex-direction: column; 
    justify-content: space-between; 
    /* 140px de padding superior para que no choque con los textos del Navbar */
    padding: 140px 20px 40px; 
    text-align: center;
  }

  .hero-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-location { 
    font-family: 'Montserrat', sans-serif; 
    font-size: 0.9rem; 
    color: #E8D5B0; 
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-shadow: 0 2px 10px rgba(0,0,0,0.7);
  }

  .hero-titles {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1rem, 4vw, 1.4rem);
    color: #FDFBF7;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-shadow: 0 2px 15px rgba(0,0,0,0.8);
  }

  /* El resorte que mantiene el centro libre */
  .hero-spacer {
    flex-grow: 1; 
    min-height: 150px;
  }

  .hero-actions { 
    display: flex; 
    gap: 1.5rem; 
    justify-content: center; 
    flex-wrap: wrap;
    margin-bottom: 3.5rem; 
  }

  .btn-primary { 
    background: #25D366; color: white; padding: 1rem 2.2rem; 
    border-radius: 50px; font-weight: 600; text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }

  .btn-secondary { 
    background: rgba(253,251,247,0.1); color: #FDFBF7; padding: 1rem 2.2rem; 
    border-radius: 50px; border: 1.5px solid #FDFBF7; text-decoration: none;
    backdrop-filter: blur(4px);
  }

  .scroll-hint { 
    color: rgba(253,251,247,0.6); font-size: 0.75rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
</style>