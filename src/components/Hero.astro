---
// Hero.astro — v4 "Logo como elemento centrado"
//
// Diagnóstico: logo-bg.webp (512×276) es la imagen del círculo logo.
// Con object-fit:cover en mobile portrait (393×852), la imagen escala
// por el eje Y y el círculo queda MÁS ANCHO que el viewport → cortado.
//
// Solución: la imagen NO es el fondo — es un elemento <img> posicionado
// en el centro de la sección. El fondo real es el gradiente extendido
// (colores extraídos de los bordes de la foto). Esto garantiza:
//   ✓ El círculo siempre se ve completo
//   ✓ Sin franjas negras
//   ✓ Texto SEO arriba, botones abajo
//   ✓ Responsive en cualquier viewport
---

<section id="inicio" class="hero" aria-label="Viviana Herrera Pastelería">

  <!-- Fondo decorativo: gradiente que imita la foto de tortas -->
  <div class="hero-bg-deco" aria-hidden="true"></div>

  <!-- El logo circular como elemento centrado, no como fondo -->
  <img
    src="/images/logo-bg.webp"
    alt="Logo Viviana Herrera Pastelería"
    class="hero-logo-img"
    loading="eager"
    fetchpriority="high"
    width="512"
    height="276"
    aria-hidden="true"
  />

  <!-- Contenido semántico -->
  <div class="hero-content">

    <!-- Textos SEO — encima del logo -->
    <div class="hero-top reveal">
      <p class="hero-location">
        <svg width="9" height="12" viewBox="0 0 10 13" fill="none" aria-hidden="true">
          <path d="M5 0C2.24 0 0 2.24 0 5c0 3.75 5 8 5 8s5-4.25 5-8c0-2.76-2.24-5-5-5zm0 6.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" fill="currentColor"/>
        </svg>
        Salto, Buenos Aires
      </p>
      <h1 class="hero-tagline">
        Tortas artesanales · Postres · Mesas dulces
      </h1>
    </div>

    <!-- Espaciador adaptable: ocupa la zona visual del logo -->
    <div class="hero-spacer" aria-hidden="true"></div>

    <!-- Botones — debajo del logo -->
    <div class="hero-bottom reveal reveal-delay-2">
      <div class="hero-actions">
        <a
          href="https://wa.me/5491100000000?text=Hola%20Viviana!%20Vi%20tu%20web%20y%20me%20gustar%C3%ADa%20consultar%20sobre%20un%20pedido"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hacer un pedido
        </a>
        <a href="#galeria" class="btn-secondary">Ver creaciones</a>
      </div>

      <p class="scroll-hint" aria-hidden="true">
        Deslizá para conocer más
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </p>
    </div>

  </div>
</section>

<style>
  /* ══════════════════════════════════════════════════════════
     HERO — v4 "Logo como elemento"
     
     El fondo real es un gradiente de tortas (cálido/oscuro).
     La imagen logo-bg.webp se trata como un <img> posicionado
     en el centro de la sección, nunca como background-image.
     Esto resuelve definitivamente el problema de recorte.
  ══════════════════════════════════════════════════════════ */

  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;

    /* Fondo: gradiente que evoca la foto de tortas y postres.
       Coincide con los bordes reales de logo-bg.webp. */
    background:
      radial-gradient(
        ellipse 160% 100% at 50% 0%,
        #e8c99a 0%,
        #c9a06e 20%,
        #8a5c3e 50%,
        #4a2e1c 80%,
        #2c1a0e 100%
      );
  }

  /* ── FONDO DECORATIVO (capa de textura) ── */
  .hero-bg-deco {
    position: absolute;
    inset: 0;
    z-index: 0;
    /* Viñeta que oscurece los bordes para profundidad */
    background: radial-gradient(
      ellipse 80% 70% at 50% 50%,
      transparent 40%,
      rgba(20, 10, 4, 0.45) 100%
    );
    pointer-events: none;
  }

  /* ── LOGO-IMG: el círculo como elemento posicionado ──────
     
     Lógica de posicionamiento:
     - position: absolute, centrado horizontalmente
     - top: 50% con transform para centrar verticalmente
     - width: clamp() que en mobile no supera el viewport
     - z-index: 1 (entre el fondo y el contenido)
     
     En cualquier viewport, el círculo siempre cabe entero.
  ──────────────────────────────────────────────────────── */
  .hero-logo-img {
    position: absolute;
    /* Centro vertical: ajustado arriba del centro geométrico
       para que los botones queden debajo con buen aire */
    top: 50%;
    left: 50%;
    transform: translate(-50%, -52%);
    z-index: 1;

    /* Ancho máximo: 92% del viewport, nunca más de 560px.
       En mobile 393px → imagen = 362px → cabe perfecta sin corte. */
    width: clamp(280px, 92vw, 560px);
    height: auto;

    /* Sombra suave para separar del fondo */
    filter:
      drop-shadow(0 8px 40px rgba(0, 0, 0, 0.55))
      drop-shadow(0 2px 12px rgba(0, 0, 0, 0.35));

    /* Animación de entrada */
    animation: logo-enter 1s ease forwards;
    opacity: 0;
  }

  @keyframes logo-enter {
    from { opacity: 0; transform: translate(-50%, -48%) scale(0.97); }
    to   { opacity: 1; transform: translate(-50%, -52%) scale(1); }
  }

  /* ── OVERLAY sobre el logo para que el texto sea legible ── */
  /* No necesitamos overlay global — el fondo oscuro ya ayuda.
     Solo suavizamos arriba y abajo donde va el texto. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        rgba(20, 10, 4, 0.70) 0%,     /* zona navbar + textos SEO */
        rgba(20, 10, 4, 0.15) 20%,
        rgba(20, 10, 4, 0.00) 38%,    /* zona del logo — limpio */
        rgba(20, 10, 4, 0.00) 60%,
        rgba(20, 10, 4, 0.20) 76%,
        rgba(20, 10, 4, 0.72) 100%    /* zona botones */
      );
    pointer-events: none;
  }

  /* ── CONTENIDO ─────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 3; /* encima del logo y del overlay */
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;

    display: flex;
    flex-direction: column;
    min-height: 100svh;
    justify-content: space-between;

    /* padding-top: deja espacio claro bajo el navbar (≈75px) + aire (30px) */
    padding-top: calc(105px + env(safe-area-inset-top, 0px));
    padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
  }

  /* ── TEXTOS SEO ── */
  .hero-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
  }

  .hero-location {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(0.78rem, 2.2vw, 0.9rem);
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #F0D99A;
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.95),
      0 0  20px rgba(0, 0, 0, 0.7);
    margin: 0;
  }

  .hero-tagline {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(0.78rem, 2.4vw, 1rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(253, 251, 247, 0.97);
    text-shadow:
      0 2px 10px rgba(0, 0, 0, 0.98),
      0 0  28px rgba(0, 0, 0, 0.8);
    line-height: 1.65;
    margin: 0;
    padding: 0;
  }

  /* ── ESPACIADOR ── */
  .hero-spacer {
    flex: 1;
    min-height: 24px;
  }

  /* ── BOTONES ── */
  .hero-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: #fff;
    padding: 0.9rem 1.8rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 4px 22px rgba(37, 211, 102, 0.50);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: #20b557;
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.60);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(253, 251, 247, 0.12);
    color: #FDFBF7;
    padding: 0.9rem 1.8rem;
    border-radius: 50px;
    border: 1.5px solid rgba(253, 251, 247, 0.60);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    white-space: nowrap;
  }

  .btn-secondary:hover {
    background: rgba(253, 251, 247, 0.22);
    border-color: rgba(253, 251, 247, 0.95);
    transform: translateY(-2px);
  }

  /* ── SCROLL HINT ── */
  .scroll-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(253, 251, 247, 0.50);
    margin: 0;
    animation: hint-bounce 2.4s ease-in-out infinite;
    flex-direction: column;
  }

  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0);    opacity: 0.50; }
    50%       { transform: translateY(6px); opacity: 0.75; }
  }

  /* ══════════════════════════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════════════════════════ */

  /* Mobile ≤ 600px */
  @media (max-width: 600px) {
    .hero-logo-img {
      /* En mobile la imagen es más ancha que el viewport sin clamp.
         92vw = 362px en 393px viewport → logo cabe entero. */
      width: clamp(260px, 92vw, 400px);
      /* Sube un poco para que haya más espacio para los botones */
      transform: translate(-50%, -54%);
    }

    .hero-content {
      padding-top: calc(88px + env(safe-area-inset-top, 0px));
      padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      justify-content: center;
    }

    /* Textos más visibles en mobile */
    .hero-location {
      font-size: 0.82rem;
      letter-spacing: 0.22em;
    }

    .hero-tagline {
      font-size: 0.82rem;
      letter-spacing: 0.14em;
    }
  }

  /* Mobile landscape */
  @media (max-width: 900px) and (orientation: landscape) {
    .hero-content {
      padding-top: calc(65px + env(safe-area-inset-top, 0px));
    }
    .hero-logo-img {
      width: clamp(180px, 55vw, 360px);
      transform: translate(-50%, -50%);
    }
    .scroll-hint { display: none; }
  }

  /* Tablet 601–900px */
  @media (min-width: 601px) and (max-width: 900px) {
    .hero-logo-img {
      width: clamp(360px, 75vw, 520px);
    }
    .hero-content {
      padding-top: calc(100px + env(safe-area-inset-top, 0px));
    }
  }

  /* Desktop > 1400px */
  @media (min-width: 1400px) {
    .hero-logo-img {
      width: min(640px, 44vw);
      transform: translate(-50%, -54%);
    }
    .hero-content {
      padding-top: 120px;
    }
  }
</style>