---
// src/components/Logo.astro
const { size = "md", variant = "dark" } = Astro.props;

const sizeClasses = {
  sm: "max-w-[120px]",
  md: "max-w-[200px]",
  lg: "max-w-[280px]",
  xl: "max-w-[350px]"
};

const variantClasses = variant === "light" ? "brightness-110 contrast-105" : "";
---

<div class={`flex items-center justify-center p-2 ${variantClasses}`}>
  <img 
    src="/images/logo-completo.webp" 
    alt="Viviana Herrera Pastelería Artesanal" 
    class={`${sizeClasses[size]} h-auto rounded-full shadow-2xl transition-transform duration-500 hover:scale-105`}
    loading="eager"
  />
</div>