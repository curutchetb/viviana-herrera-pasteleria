---
import Logo from './Logo.astro';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <Logo size="md" variant="dark" />
        <p class="footer-tagline">
          Pastelería artesanal en<br/>Salto, Buenos Aires
        </p>
        <a
          href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Quisiera%20hacer%20un%20pedido"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-wa"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribirme ahora
        </a>
      </div>

      <div class="footer-links">
        <h4>Navegación</h4>
        <nav>
          <a href="#inicio">Inicio</a>
          <a href="#nosotros">Sobre mí</a>
          <a href="#galeria">Galería</a>
          <a href="#pedidos">Configurar pedido</a>
          <a href="#faqs">Preguntas frecuentes</a>
        </nav>
      </div>

      <div class="footer-contact">
        <h4>Contacto</h4>
        <div class="contact-items">
          <div class="contact-item">
            <span>📍</span>
            <span>Salto, Buenos Aires, Argentina</span>
          </div>
          <div class="contact-item">
            <span>💬</span>
            <a href="https://wa.me/5492474453333" target="_blank" rel="noopener noreferrer">
              WhatsApp (consultar número)
            </a>
          </div>
          <div class="contact-item">
            <span>📸</span>
            <a href="https://instagram.com/vivianaherreratortasypostres" target="_blank" rel="noopener noreferrer">
              Instagram
            </a>
          </div>
          <div class="contact-item">
            <span>👍</span>
            <a href="https://facebook.com/vivianaherreratortasypostres" target="_blank" rel="noopener noreferrer">
              Facebook
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Viviana Herrera Pastelería · Salto, Buenos Aires</p>
      <p class="footer-love">Hecho con 🌸 y mucho azúcar</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--grafito);
    color: rgba(253,251,247,0.7);
    padding: 4rem 1.5rem 2rem;
  }

  .footer-inner { max-width: 1100px; margin: 0 auto; }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(253,251,247,0.08);
  }

  .footer-tagline {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(253,251,247,0.5);
    margin: 1rem 0;
  }

  .footer-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #25D366;
    color: white;
    padding: 0.55rem 1.1rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 2px 12px rgba(37,211,102,0.3);
  }

  .footer-wa:hover { background: #20b557; transform: translateY(-1px); }

  .footer-links h4, .footer-contact h4 {
    font-family: 'Playfair Display', serif;
    font-size: 0.9rem;
    color: rgba(253,251,247,0.9);
    margin-bottom: 1.25rem;
    font-weight: 500;
  }

  .footer-links nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    color: rgba(253,251,247,0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover { color: var(--rosa-viejo); }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    color: rgba(253,251,247,0.5);
  }

  .contact-item a {
    color: rgba(253,251,247,0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-item a:hover { color: var(--rosa-viejo); }

  .footer-bottom {
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom p {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    color: rgba(253,251,247,0.3);
  }

  .footer-love { color: rgba(253,251,247,0.4) !important; }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { justify-content: center; text-align: center; }
  }
</style>
