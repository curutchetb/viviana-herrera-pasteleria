---
import Logo from './Logo.astro';
---

<nav id="navbar" class="navbar">
  <div class="nav-inner">
    <!-- Logo (solo visible al scrollear) -->
    <a href="#inicio" class="nav-logo" aria-label="Volver al inicio">
      <Logo size="sm" variant="dark" />
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#pedidos">Pedir torta</a></li>
      <li><a href="#galeria">Galería</a></li>
      <li><a href="#nosotros">Nosotros</a></li>
      <li><a href="#faqs">Preguntas</a></li>
    </ul>

    <!-- Desktop WA CTA -->
    <a
      href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Quer%C3%ADa%20consultar%20sobre%20un%20pedido"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Mobile: botón hamburger (solo ≤768px) -->
    <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- MOBILE MENU — drawer con botones grandes y claros -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <ul role="list">
      <li>
        <a href="#pedidos" class="mobile-link mobile-link--highlight">
          <span class="mobile-link-icon">🎂</span>
          <span>Pedir una torta</span>
          <span class="mobile-link-arrow">→</span>
        </a>
      </li>
      <li>
        <a href="#galeria" class="mobile-link">
          <span class="mobile-link-icon">📸</span>
          <span>Ver galería</span>
          <span class="mobile-link-arrow">→</span>
        </a>
      </li>
      <li>
        <a href="#nosotros" class="mobile-link">
          <span class="mobile-link-icon">👩‍🍳</span>
          <span>Sobre Viviana</span>
          <span class="mobile-link-arrow">→</span>
        </a>
      </li>
      <li>
        <a href="#faqs" class="mobile-link">
          <span class="mobile-link-icon">❓</span>
          <span>Preguntas frecuentes</span>
          <span class="mobile-link-arrow">→</span>
        </a>
      </li>
      <li>
        <a
          href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Quisiera%20hacer%20un%20pedido"
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-link mobile-wa"
        >
          <span class="mobile-link-icon">💬</span>
          <span>Escribirme por WhatsApp</span>
          <span class="mobile-link-arrow">→</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 80);
  });

  hamburger?.addEventListener('click', () => {
    const open = mobileMenu?.hasAttribute('hidden') === false;
    if (open) {
      mobileMenu?.setAttribute('hidden', '');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('open');
    } else {
      mobileMenu?.removeAttribute('hidden');
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.classList.add('open');
    }
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.setAttribute('hidden', '');
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.classList.remove('open');
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    transition: background 0.35s ease, box-shadow 0.35s ease;
    padding-top: calc(0.85rem + env(safe-area-inset-top, 0px));
    padding-bottom: 0.85rem;
  }

  .navbar.scrolled {
    background: rgba(253,251,247,0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 20px rgba(51,33,28,0.08);
    padding-top: calc(0.35rem + env(safe-area-inset-top, 0px));
    padding-bottom: 0.35rem;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-logo {
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .navbar.scrolled .nav-logo {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── DESKTOP LINKS ── */
  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(253,251,247,0.85);
    text-decoration: none;
    position: relative;
    transition: color 0.2s;
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }

  .navbar.scrolled .nav-links a {
    color: var(--grafito);
    text-shadow: none;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--rosa-viejo);
    transition: width 0.25s;
  }

  .nav-links a:hover { color: var(--rosa-oscuro); }
  .nav-links a:hover::after { width: 100%; }
  .navbar.scrolled .nav-links a:hover { color: var(--rosa-oscuro); }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #25D366;
    color: white;
    padding: 0.5rem 1.1rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 2px 12px rgba(37,211,102,0.3);
  }

  .nav-cta:hover { background: #20b557; transform: translateY(-1px); }

  /* ── HAMBURGER ── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: rgba(0,0,0,0.25);
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 10px;
    cursor: pointer;
    padding: 0.55rem 0.65rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 0.2s;
  }

  .navbar.scrolled .hamburger {
    background: rgba(253,251,247,0.9);
    border-color: rgba(51,33,28,0.15);
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(253,251,247,0.9);
    transition: all 0.3s;
    transform-origin: center;
  }

  .navbar.scrolled .hamburger span {
    background: var(--grafito);
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── MOBILE MENU DRAWER ──
     Diseñado para personas mayores:
     - Botones grandes con altura mínima táctil (56px)
     - Iconos + texto + flecha → completamente claro
     - Primer ítem destacado en rosa (la acción principal)
  ── */
  .mobile-menu {
    background: rgba(253,251,247,0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(212,165,165,0.25);
    padding: 0.5rem 1rem 1rem;
  }

  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;         /* grande — legible para personas mayores */
    font-weight: 500;
    color: var(--grafito);
    text-decoration: none;
    padding: 0.9rem 1rem;    /* área táctil generosa ≥ 44px */
    border-radius: 12px;
    transition: background 0.15s, color 0.15s;
    min-height: 56px;        /* mínimo recomendado para táctil */
  }

  .mobile-link:hover,
  .mobile-link:active {
    background: var(--rosa-claro);
    color: var(--rosa-oscuro);
  }

  /* Primer item — acción principal: pedir torta */
  .mobile-link--highlight {
    background: var(--rosa-claro);
    color: var(--rosa-oscuro);
    font-weight: 700;
    border: 1.5px solid rgba(212,165,165,0.4);
  }

  .mobile-link--highlight:hover {
    background: var(--rosa-viejo);
    color: white;
  }

  .mobile-link-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    width: 1.6rem;
    text-align: center;
  }

  .mobile-link-arrow {
    margin-left: auto;
    font-size: 1rem;
    color: var(--rosa-viejo);
    opacity: 0.7;
  }

  /* WhatsApp link */
  .mobile-wa {
    background: #f0fdf4;
    color: #166534 !important;
    border: 1.5px solid rgba(37,211,102,0.25);
    font-weight: 600;
    margin-top: 0.25rem;
  }

  .mobile-wa:hover {
    background: #dcfce7 !important;
    color: #166534 !important;
  }

  .mobile-wa .mobile-link-arrow { color: #25D366; opacity: 1; }

  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>
