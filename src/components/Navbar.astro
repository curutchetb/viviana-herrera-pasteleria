---
import Logo from './Logo.astro';
---

<nav id="navbar" class="navbar">
  <div class="nav-inner">
    <a href="#inicio" class="nav-logo" aria-label="Volver al inicio">
      <Logo size="sm" variant="dark" />
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#pedidos">Pedir torta</a></li>
      <li><a href="#galeria">Galería</a></li>
      <li><a href="#nosotros">Sobre mí</a></li>
      <li><a href="#faqs">Preguntas</a></li>
    </ul>

    <a
      href="https://wa.me/5492474453333?text=Hola%20Viviana!%20Quer%C3%ADa%20consultar%20sobre%20un%20pedido"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
  </div>
</nav>

<div class="bottom-nav">
  <ul role="list">
    <li>
      <a href="#pedidos" class="bottom-link highlight">
        <span class="bottom-icon">🎂</span>
        <span class="bottom-text">Pedidos</span>
      </a>
    </li>
    <li>
      <a href="#galeria" class="bottom-link">
        <span class="bottom-icon">📸</span>
        <span class="bottom-text">Galería</span>
      </a>
    </li>
    <li>
      <a href="#faqs" class="bottom-link">
        <span class="bottom-icon">❓</span>
        <span class="bottom-text">Ayuda</span>
      </a>
    </li>
    <li>
      <a href="https://wa.me/5492474453333" target="_blank" class="bottom-link wa">
        <span class="bottom-icon">💬</span>
        <span class="bottom-text">WhatsApp</span>
      </a>
    </li>
  </ul>
</div>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 80);
  });
</script>

<style>
  /* --- NAVBAR BASE (Desktop) --- */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: transparent;
    transition: all 0.35s ease;
    padding-top: calc(0.85rem + env(safe-area-inset-top, 0px));
    padding-bottom: 0.85rem;
  }

  .navbar.scrolled {
    background: rgba(253,251,247,0.96);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 20px rgba(51,33,28,0.08);
    padding-top: calc(0.35rem + env(safe-area-inset-top, 0px));
    padding-bottom: 0.35rem;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo { opacity: 0; transition: opacity 0.3s; pointer-events: none; }
  .navbar.scrolled .nav-logo { opacity: 1; pointer-events: auto; }

  .nav-links { display: flex; list-style: none; gap: 2rem; }
  .nav-links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    color: rgba(253,251,247,0.85);
    text-decoration: none;
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }
  .navbar.scrolled .nav-links a { color: var(--grafito); text-shadow: none; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #25D366;
    color: white;
    padding: 0.5rem 1.1rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
  }

  /* --- BOTTOM NAV (Mobile) --- */
  .bottom-nav {
    display: none; /* Oculto en PC */
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #ffffff;
    z-index: 1000;
    border-top: 1px solid rgba(212,165,165,0.3);
    padding-top: 12px;
    padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
  }

  .bottom-nav ul {
    display: flex;
    justify-content: space-around;
    list-style: none;
    max-width: 500px;
    margin: 0 auto;
    padding: 0 10px;
  }

  .bottom-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--grafito);
    gap: 5px;
    min-width: 65px;
  }

  .bottom-icon { font-size: 1.5rem; }
  .bottom-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* Item resaltado (Pedidos) */
  .bottom-link.highlight .bottom-text { color: var(--rosa-oscuro); }
  .bottom-link.highlight .bottom-icon { transform: scale(1.2); }

  /* WhatsApp resaltado en verde */
  .bottom-link.wa .bottom-text { color: #166534; }

  @media (max-width: 768px) {
    .nav-links, .nav-cta, .nav-logo { display: none !important; }
    .bottom-nav { display: block; }
    .navbar { background: transparent !important; box-shadow: none !important; }

    /* Evita que el contenido quede tapado por la barra inferior */
    :global(body) { padding-bottom: 85px; }
  }
</style>