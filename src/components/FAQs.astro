---
const faqs = [
  {
    q: "¿Con cuánto tiempo de anticipación debo hacer el pedido?",
    a: "Para tortas personalizadas se necesita un mínimo de 5 a 7 días de anticipación. Para fechas especiales como feriados o fin de semana largo, se recomienda reservar con 2 semanas."
  },
  {
    q: "¿Hacen entregas a domicilio?",
    a: "El retiro es en nuestro domicilio en Salto, Buenos Aires. En algunos casos especiales se puede coordinar entrega con un costo adicional según la distancia. Consultanos por WhatsApp."
  },
  {
    q: "¿Cuáles son las formas de pago?",
    a: "Aceptamos efectivo, transferencia bancaria y Mercado Pago. Se solicita un 50% de seña al momento de confirmar el pedido para garantizar la reserva."
  },
  {
    q: "¿Puedo pedir una torta con diseño temático personalizado?",
    a: "¡Claro que sí! Las tortas temáticas son una especialidad. Podés indicarnos el tema, colores y cualquier referencia que tengas, y lo adaptamos para vos."
  },
  {
    q: "¿Cuántas personas entran por kilo de torta?",
    a: "Aproximadamente 8 porciones por kilo. Una torta de 1 kg alcanza para unas 8 personas, 2 kg para 16 y 3 kg para 24 o más, dependiendo del tamaño de las porciones."
  },
  {
    q: "¿Hacen postresitos para eventos o mesas dulces?",
    a: "Sí, ofrecemos postres individuales en copas (lemon pie, tiramisú, frutas, chocotorta y más) y mesas dulces completas. Consultanos según el número de invitados."
  },
  {
    q: "¿Pueden escribirle el nombre a la torta?",
    a: "Por supuesto, es un servicio estándar sin costo adicional. Simplemente indicanos el nombre o mensaje que querés que lleve la torta al hacer el pedido."
  },
];
---

<section id="faqs" class="faqs section-padding">
  <div class="faqs-inner">
    <div class="section-header reveal">
      <div class="section-tag">Preguntas frecuentes</div>
      <h2>Todo lo que<br/><em>necesitás saber</em></h2>
    </div>

    <div class="faqs-grid">
      {faqs.map((faq, i) => (
        <details class={`faq-item reveal reveal-delay-${(i % 3) + 1}`}>
          <summary class="faq-q">
            <span>{faq.q}</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <p class="faq-a">{faq.a}</p>
        </details>
      ))}
    </div>

    <!-- Social links -->
    <div class="social-strip reveal">
      <p>Seguime en redes</p>
      <div class="social-btns">
        <a
          href="https://instagram.com/vivianaherreratortasypostres"
          target="_blank"
          rel="noopener noreferrer"
          class="social-btn instagram"
          aria-label="Instagram de Viviana Herrera Pastelería"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @vivianaherreratortasypostres
        </a>
        <a
          href="https://facebook.com/vivianaherreratortasypostres"
          target="_blank"
          rel="noopener noreferrer"
          class="social-btn facebook"
          aria-label="Facebook de Viviana Herrera Pastelería"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Viviana Herrera Pastelería
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .faqs {
    background: #FDFBF7;
  }

  .section-padding { padding: 6rem 1.5rem; }

  .faqs-inner { max-width: 800px; margin: 0 auto; }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rosa-viejo);
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-tag::before, .section-tag::after {
    content: '';
    width: 30px;
    height: 1px;
    background: var(--rosa-viejo);
    opacity: 0.4;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.6rem);
    line-height: 1.2;
    color: var(--grafito);
    margin-bottom: 0.75rem;
  }

  h2 em { font-style: italic; color: var(--rosa-oscuro); }

  .faqs-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    border: 1px solid rgba(212,165,165,0.2);
    border-radius: 14px;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .faq-item[open] {
    box-shadow: 0 4px 20px rgba(212,165,165,0.15);
    border-color: rgba(212,165,165,0.4);
  }

  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--grafito);
    cursor: pointer;
    list-style: none;
    user-select: none;
    background: white;
    transition: background 0.2s ease;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-item[open] .faq-q {
    background: var(--rosa-claro);
  }

  .faq-icon {
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--rosa-viejo);
    flex-shrink: 0;
    transition: transform 0.3s ease;
    line-height: 1;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.84rem;
    line-height: 1.7;
    color: #666;
    padding: 1rem 1.5rem 1.25rem;
    background: white;
    border-top: 1px solid rgba(212,165,165,0.15);
  }

  /* Social strip */
  .social-strip {
    margin-top: 4rem;
    text-align: center;
    padding: 2.5rem;
    background: linear-gradient(135deg, var(--rosa-claro), #FDF5F5);
    border-radius: 20px;
    border: 1px solid rgba(212,165,165,0.2);
  }

  .social-strip p {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--grafito);
    margin-bottom: 1.25rem;
  }

  .social-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .instagram {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white;
  }

  .instagram:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(220,39,67,0.4); }

  .facebook {
    background: #1877F2;
    color: white;
  }

  .facebook:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(24,119,242,0.4); }
</style>
